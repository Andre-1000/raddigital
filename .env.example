# Copie este arquivo para .env e ajuste os valores para o seu ambiente
DEBUG=True
SECRET_KEY=troque-esta-chave-por-uma-gerada-com-django-get-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

DB_ENGINE=django.db.backends.postgresql
DB_NAME=sistema_rad
DB_USER=rad_dev
DB_PASSWORD=defina-uma-senha
DB_HOST=localhost
DB_PORT=5432

# Validade do token de autenticacao (RG-AUTH-003)
VALIDADE_TOKEN_DIAS=7

# Ativa a estrutura de logs (secao 8 de PADROES_E_DIRETRIZES)
LOGS_ATIVOS=False
